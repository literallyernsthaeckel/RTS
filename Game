<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
  <title>RTS Mobile Refatorado</title>
  <style>
    :root {
      --bg: #111613;
      --panel: rgba(18, 24, 20, 0.94);
      --text: #e6e6e6;
      --muted: #b6b6b6;
      --btn: #34453a;
      --btn-active: #4e6a56;
      --danger: #d05d5d;
      --accent: #d8aa72;
      --cyan: #7ed6ff;
    }
    * { box-sizing: border-box; touch-action: none; user-select: none; -webkit-user-select: none; }
    html, body {
      margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden;
      background: var(--bg); font-family: system-ui, -apple-system, sans-serif;
    }
    #gameCanvas { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 1; }

    .overlay {
      position: absolute; inset: 0; z-index: 100;
      display: flex; flex-direction: column; justify-content: center; align-items: center;
      background: rgba(10, 14, 11, 0.97); color: var(--text);
    }
    .hidden { display: none !important; }
    .title {
      font-size: 36px; font-weight: 800; letter-spacing: 3px; text-transform: uppercase;
      color: var(--accent); margin-bottom: 28px;
    }
    .subtitle { color: var(--muted); font-size: 14px; margin-bottom: 18px; text-align: center; max-width: 300px; }
    .menu-btn {
      background: var(--btn); color: var(--text); border: 2px solid #58635b; border-radius: 12px;
      font-size: 20px; font-weight: 700; min-width: 220px; padding: 16px 28px; margin: 10px; cursor: pointer;
    }
    .menu-btn:active { background: var(--btn-active); transform: scale(0.98); }
    .bot-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    #uiLayer {
      position: absolute; inset: 0; z-index: 10; pointer-events: none;
      display: flex; flex-direction: column; justify-content: space-between;
    }
    .hud {
      pointer-events: auto; background: var(--panel); color: var(--text);
      box-shadow: 0 4px 15px rgba(0,0,0,0.45);
    }
    .hud-top {
      display: flex; flex-wrap: wrap; justify-content: center; gap: 14px; padding: 10px 12px;
      border-bottom: 1px solid #2d3730;
    }
    .hud-bottom {
      padding: 8px 10px calc(env(safe-area-inset-bottom, 0px) + 10px);
      border-top: 1px solid #2d3730;
    }
    .res-item { display: flex; align-items: center; gap: 6px; font-weight: 700; font-size: 14px; }
    .res-icon { width: 12px; height: 12px; border-radius: 3px; }
    #selectionInfo { color: var(--accent); font-size: 12px; font-weight: 800; }
    #actions {
      display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; align-items: center;
    }
    .action-btn {
      background: var(--btn); color: var(--text); border: 1px solid #58635b; border-radius: 8px;
      padding: 10px 14px; min-width: 92px; font-size: 12px; font-weight: 800; text-align: center;
      pointer-events: auto;
    }
    .action-btn:active:not(:disabled) { background: var(--btn-active); transform: scale(0.97); }
    .action-btn:disabled { opacity: 0.4; filter: grayscale(1); }
    .action-btn small { display: block; margin-top: 2px; font-size: 10px; color: var(--muted); }
    .limit-info { color: var(--cyan); }

    #msgBox {
      position: absolute; top: 74px; left: 50%; transform: translateX(-50%);
      max-width: min(88vw, 520px);
      background: rgba(0,0,0,0.76); color: #fff; border: 1px solid #424242; border-radius: 24px;
      padding: 12px 18px; font-size: 13px; text-align: center; z-index: 40; opacity: 0; transition: opacity 0.2s;
      pointer-events: none;
    }
  </style>
</head>
<body>
  <div id="mainMenu" class="overlay">
    <div class="title">RTS CORE</div>
    <div class="subtitle">Protótipo mobile com facções, economia coerente, combate automático e bots sem trapaça.</div>
    <button class="menu-btn" onclick="UI.toBotMenu()">Jogar</button>
  </div>

  <div id="botMenu" class="overlay hidden">
    <div class="title" style="font-size:24px">Quantos inimigos?</div>
    <div class="subtitle">Todos os bots usam as mesmas regras do jogador.</div>
    <div class="bot-grid">
      <button class="menu-btn" onclick="Game.start(1)">1 BOT</button>
      <button class="menu-btn" onclick="Game.start(2)">2 BOTS</button>
      <button class="menu-btn" onclick="Game.start(3)">3 BOTS</button>
      <button class="menu-btn" onclick="Game.start(4)">4 BOTS</button>
    </div>
  </div>

  <div id="endMenu" class="overlay hidden">
    <div id="endTitle" class="title">Vitória</div>
    <div id="endSubtitle" class="subtitle">A prefeitura inimiga caiu.</div>
    <button class="menu-btn" onclick="UI.toBotMenu()">Jogar novamente</button>
  </div>

  <canvas id="gameCanvas"></canvas>

  <div id="uiLayer" class="hidden">
    <div class="hud hud-top">
      <div class="res-item"><div class="res-icon" style="background:#8b5a2b"></div><span id="valWood">0</span></div>
      <div class="res-item"><div class="res-icon" style="background:#858585"></div><span id="valStone">0</span></div>
      <div class="res-item"><div class="res-icon" style="background:#f4d03f"></div><span id="valGrain">0</span></div>
      <div id="selectionInfo">Sem seleção</div>
    </div>

    <div id="msgBox">Mensagem</div>

    <div class="hud hud-bottom">
      <div id="actions">
        <button id="buildMine" class="action-btn" onclick="UI.prepBuild(B_MINE)">Mina<small>10M <span id="lim-2" class="limit-info">(0/2)</span></small></button>
        <button id="buildLumber" class="action-btn" onclick="UI.prepBuild(B_WOOD)">Lenha<small>10M <span id="lim-3" class="limit-info">(0/2)</span></small></button>
        <button id="buildFarm" class="action-btn" onclick="UI.prepBuild(B_FARM)">Fazenda<small>10M 5P <span id="lim-4" class="limit-info">(0/1)</span></small></button>
        <button id="buildBarracks" class="action-btn" onclick="UI.prepBuild(B_BARR)">Quartel<small>20M 20P <span id="lim-5" class="limit-info">(0/1)</span></small></button>
        <button id="spawnUnit" class="action-btn hidden" onclick="Game.requestUnit()">Soldado<small>10G</small></button>
        <button id="cancelBuild" class="action-btn hidden" onclick="UI.cancelBuild()" style="border-color:#b96a6a;color:#ffd0d0">Cancelar<small>Construção</small></button>
      </div>
    </div>
  </div>

<script>
'use strict';

// ============================================================
// RTS MOBILE REFATORADO
// - Facções reais para player e bots
// - Combate automático com auto-defesa
// - Simulação fixa independente do FPS
// - Seleção por gesto no mobile
// - Bot respeitando economia, limites e quartel
// ============================================================

const TILE = 32;
const MAP_SZ = 60;
const WORLD_SZ = TILE * MAP_SZ;
const MAX_U = 512;
const MAX_B = 192;
const MAX_F = 5;
const FIXED_STEP = 1 / 30;
const ECON_INTERVAL = 2.0;
const BOT_INTERVAL = 1.0;
const HASH_CELL_SIZE = 64;
const HASH_W = Math.ceil(WORLD_SZ / HASH_CELL_SIZE);
const HASH_H = Math.ceil(WORLD_SZ / HASH_CELL_SIZE);
const HASH_COUNT = HASH_W * HASH_H;
const MAX_SELECTION = 64;
const UNIT_CAP = 60;
const TAP_SLOP2 = 144;
const RETARGET_INTERVAL = 0.35;
const TRAIN_TIME = 3.0;
const MAX_TRAIN_QUEUE = 5;
const BOT_TRAIN_DELAY = 14.0;
const BOT_ARMY_SOFT_CAP = 6;
const BOT_ATTACK_MIN_ARMY = 6;
const BOT_ATTACK_COOLDOWN = 18;
const START_MIN_DIST_TILES = 18;
const FLASH_MAX = 0.22;

// Tipos de construção
const B_HALL = 1;
const B_MINE = 2;
const B_WOOD = 3;
const B_FARM = 4;
const B_BARR = 5;

// Estados de unidade
const STATE_IDLE = 0;
const STATE_MOVE = 1;
const STATE_ATTACK = 2;
const STATE_CHASE = 3;
const STATE_ATTACK_MOVE = 4;

const ORDER_NONE = 0;
const ORDER_MOVE = 1;
const ORDER_ATTACK = 2;
const ORDER_ATTACK_MOVE = 3;

// Banco fixo de configuração
const BuildCfg = {
  1: { name: 'Prefeitura', w: 3, h: 3, costW: 0,  costS: 0,  costG: 0, hp: 1000, income: [1,1,1], vision: 190 },
  2: { name: 'Mina',       w: 2, h: 2, costW: 10, costS: 0,  costG: 0, hp: 480,  income: [0,2,0], vision: 110 },
  3: { name: 'Lenha',      w: 2, h: 2, costW: 10, costS: 0,  costG: 0, hp: 480,  income: [2,0,0], vision: 110 },
  4: { name: 'Fazenda',    w: 3, h: 3, costW: 10, costS: 5,  costG: 0, hp: 520,  income: [0,0,5], vision: 110 },
  5: { name: 'Quartel',    w: 2, h: 2, costW: 20, costS: 20, costG: 0, hp: 650,  income: [0,0,0], vision: 150 }
};

const UnitCfg = {
  hp: 100,
  speed: 58,
  range: 26,
  aggro: 110,
  chase: 180,
  vision: 150,
  cooldown: 0.7,
  damage: 10,
  hitRadius: 8,
  grainCost: 10
};

const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d', { alpha: false });

const Temp = new Float32Array(2);
const TargetPoint = new Float32Array(2);
const SpawnPoint = new Float32Array(2);
const mapGrid = new Int16Array(MAP_SZ * MAP_SZ).fill(-1);
const hashHead = new Int16Array(HASH_COUNT).fill(-1);
const hashNext = new Int16Array(MAX_U).fill(-1);

const Units = {
  active: new Uint8Array(MAX_U),
  uid: new Int32Array(MAX_U),
  faction: new Uint8Array(MAX_U),
  x: new Float32Array(MAX_U),
  y: new Float32Array(MAX_U),
  tx: new Float32Array(MAX_U),
  ty: new Float32Array(MAX_U),
  homeX: new Float32Array(MAX_U),
  homeY: new Float32Array(MAX_U),
  hp: new Int16Array(MAX_U),
  state: new Uint8Array(MAX_U),
  targetType: new Uint8Array(MAX_U), // 0 nenhum, 1 unidade, 2 prédio
  targetId: new Int16Array(MAX_U),
  targetUid: new Int32Array(MAX_U),
  cooldown: new Float32Array(MAX_U),
  scanTimer: new Float32Array(MAX_U),
  flash: new Float32Array(MAX_U),
  attackRange: new Float32Array(MAX_U),
  aggroRange: new Float32Array(MAX_U),
  chaseRange: new Float32Array(MAX_U),
  damage: new Int16Array(MAX_U),
  speed: new Float32Array(MAX_U),
  visionRange: new Float32Array(MAX_U),
  order: new Uint8Array(MAX_U),
  hasWaypoint: new Uint8Array(MAX_U),
  wayX: new Float32Array(MAX_U),
  wayY: new Float32Array(MAX_U),
  blockedTime: new Float32Array(MAX_U)
};

const Builds = {
  active: new Uint8Array(MAX_B),
  uid: new Int32Array(MAX_B),
  faction: new Uint8Array(MAX_B),
  type: new Uint8Array(MAX_B),
  tx: new Int16Array(MAX_B),
  ty: new Int16Array(MAX_B),
  w: new Int8Array(MAX_B),
  h: new Int8Array(MAX_B),
  hp: new Int16Array(MAX_B),
  queue: new Float32Array(MAX_B),
  queueCount: new Uint8Array(MAX_B),
  flash: new Float32Array(MAX_B)
};

const uFree = [];
const bFree = [];
for (let i = MAX_U - 1; i >= 0; i--) uFree.push(i);
for (let i = MAX_B - 1; i >= 0; i--) bFree.push(i);

const Factions = [];

const Pings = {
  count: 0,
  x: new Float32Array(16),
  y: new Float32Array(16),
  t: new Float32Array(16)
};

const Sel = {
  count: 0,
  ids: new Int16Array(MAX_SELECTION)
};

const Engine = {
  running: false,
  uidGen: 1,
  cam: { x: WORLD_SZ / 2, y: WORLD_SZ / 2, z: 1 },
  selectedBuilding: -1,
  buildType: 0,
  placingStart: false,
  pendingBotCount: 0,
  msgTimer: 0,
  econAcc: 0,
  botAcc: 0,
  pulse: 0,
  lastTime: 0,
  acc: 0,
  mini: { x: 0, y: 0, size: 0 },
  drag: {
    active: false,
    pointerId: -1,
    pointerType: '',
    button: 0,
    mode: 0, // 0 nenhum, 1 tap, 2 camera, 3 select, 4 minimapa
    originSx: 0, originSy: 0,
    startSx: 0, startSy: 0,
    sx: 0, sy: 0,
    startWx: 0, startWy: 0,
    wx: 0, wy: 0,
    boxX0: 0, boxY0: 0, boxX1: 0, boxY1: 0,
    overOwnUnit: -1
  }
};

function resize() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
  clampCamera();
}
window.addEventListener('resize', resize);
resize();

function toWorld(sx, sy) {
  Temp[0] = (sx - canvas.width * 0.5) / Engine.cam.z + Engine.cam.x;
  Temp[1] = (sy - canvas.height * 0.5) / Engine.cam.z + Engine.cam.y;
}

function clamp(v, a, b) { return v < a ? a : (v > b ? b : v); }
function distSq(x1, y1, x2, y2) { const dx = x2 - x1, dy = y2 - y1; return dx * dx + dy * dy; }
function clampCamera() {
  const halfW = canvas.width * 0.5 / Engine.cam.z;
  const halfH = canvas.height * 0.5 / Engine.cam.z;
  const minX = halfW;
  const maxX = WORLD_SZ - halfW;
  const minY = halfH;
  const maxY = WORLD_SZ - halfH;
  Engine.cam.x = minX > maxX ? WORLD_SZ * 0.5 : clamp(Engine.cam.x, minX, maxX);
  Engine.cam.y = minY > maxY ? WORLD_SZ * 0.5 : clamp(Engine.cam.y, minY, maxY);
}

function layoutMinimap() {
  const size = clamp(Math.min(canvas.width * 0.28, canvas.height * 0.22), 96, 148);
  Engine.mini.size = size;
  Engine.mini.x = canvas.width - size - 12;
  Engine.mini.y = 82;
}

function isOnMinimap(sx, sy) {
  layoutMinimap();
  return sx >= Engine.mini.x && sy >= Engine.mini.y && sx <= Engine.mini.x + Engine.mini.size && sy <= Engine.mini.y + Engine.mini.size;
}

function focusCameraFromMinimap(sx, sy) {
  layoutMinimap();
  const mx = clamp((sx - Engine.mini.x) / Engine.mini.size, 0, 1);
  const my = clamp((sy - Engine.mini.y) / Engine.mini.size, 0, 1);
  Engine.cam.x = mx * WORLD_SZ;
  Engine.cam.y = my * WORLD_SZ;
  clampCamera();
}
function hashIndex(x, y) {
  let hx = (x / HASH_CELL_SIZE) | 0;
  let hy = (y / HASH_CELL_SIZE) | 0;
  if (hx < 0) hx = 0; else if (hx >= HASH_W) hx = HASH_W - 1;
  if (hy < 0) hy = 0; else if (hy >= HASH_H) hy = HASH_H - 1;
  return hy * HASH_W + hx;
}
function isInsideMapTile(tx, ty) { return tx >= 0 && ty >= 0 && tx < MAP_SZ && ty < MAP_SZ; }
function factionColor(fid) { return fid === 0 ? '#5a8761' : ['#b64242','#c86f2d','#6c53c8','#aa3d78'][fid - 1] || '#b64242'; }
function buildingLabel(type) { return BuildCfg[type].name; }

function clearSelection() {
  Sel.count = 0;
  Engine.selectedBuilding = -1;
  UI.updateSelectionInfo();
}

function setSingleSelection(id) {
  Sel.count = 1;
  Sel.ids[0] = id;
  Engine.selectedBuilding = -1;
  UI.updateSelectionInfo();
}

function selectBuilding(id) {
  Sel.count = 0;
  Engine.selectedBuilding = id;
  UI.updateSelectionInfo();
}

function addPing(x, y) {
  let i;
  if (Pings.count < Pings.x.length) {
    i = Pings.count++;
  } else {
    for (let k = 0; k < Pings.count - 1; k++) {
      Pings.x[k] = Pings.x[k + 1];
      Pings.y[k] = Pings.y[k + 1];
      Pings.t[k] = Pings.t[k + 1];
    }
    i = Pings.count - 1;
  }
  Pings.x[i] = x;
  Pings.y[i] = y;
  Pings.t[i] = 0.4;
}

function createFaction(isAI) {
  const id = Factions.length;
  Factions.push({
    id,
    isAI,
    wood: 150,
    stone: 50,
    grain: 20,
    limits: { [B_MINE]: 2, [B_WOOD]: 2, [B_FARM]: 1, [B_BARR]: 1 },
    current: { [B_MINE]: 0, [B_WOOD]: 0, [B_FARM]: 0, [B_BARR]: 0 },
    aiPhase: 0,
    aiAttackCooldown: 0,
    aiTrainCooldown: isAI ? BOT_TRAIN_DELAY : 0
  });
  return id;
}

function canAfford(fId, type) {
  const f = Factions[fId];
  const c = BuildCfg[type];
  return f.wood >= c.costW && f.stone >= c.costS && f.grain >= c.costG;
}

function payForBuild(fId, type) {
  const f = Factions[fId];
  const c = BuildCfg[type];
  f.wood -= c.costW;
  f.stone -= c.costS;
  f.grain -= c.costG;
}

function canPlaceBuilding(tx, ty, w, h) {
  if (tx < 0 || ty < 0 || tx + w > MAP_SZ || ty + h > MAP_SZ) return false;
  for (let yy = 0; yy < h; yy++) {
    for (let xx = 0; xx < w; xx++) {
      if (mapGrid[(ty + yy) * MAP_SZ + (tx + xx)] !== -1) return false;
    }
  }
  return true;
}

function spawnBuilding(factionId, type, tx, ty) {
  if (bFree.length === 0) return -1;
  const cfg = BuildCfg[type];
  if (!canPlaceBuilding(tx, ty, cfg.w, cfg.h)) return -1;

  const id = bFree.pop();
  Builds.active[id] = 1;
  Builds.uid[id] = ++Engine.uidGen;
  Builds.faction[id] = factionId;
  Builds.type[id] = type;
  Builds.tx[id] = tx;
  Builds.ty[id] = ty;
  Builds.w[id] = cfg.w;
  Builds.h[id] = cfg.h;
  Builds.hp[id] = cfg.hp;
  Builds.queue[id] = 0;
  Builds.queueCount[id] = 0;
  Builds.flash[id] = 0;

  for (let yy = 0; yy < cfg.h; yy++) {
    for (let xx = 0; xx < cfg.w; xx++) {
      mapGrid[(ty + yy) * MAP_SZ + (tx + xx)] = id;
    }
  }

  if (type !== B_HALL) {
    Factions[factionId].current[type]++;
  }
  return id;
}

function distSqBetweenHallTiles(ax, ay, bx, by) {
  const aw = BuildCfg[B_HALL].w * 0.5;
  const ah = BuildCfg[B_HALL].h * 0.5;
  const dx = (ax + aw) - (bx + aw);
  const dy = (ay + ah) - (by + ah);
  return dx * dx + dy * dy;
}

function minDistSqToExistingHalls(tx, ty) {
  let best = 1e30;
  for (let i = 0; i < MAX_B; i++) {
    if (!Builds.active[i] || Builds.type[i] !== B_HALL) continue;
    const d = distSqBetweenHallTiles(tx, ty, Builds.tx[i], Builds.ty[i]);
    if (d < best) best = d;
  }
  return best;
}

function placeBotHall(fId, minDistTiles) {
  const cfg = BuildCfg[B_HALL];
  let bestTx = -1;
  let bestTy = -1;
  let bestScore = -1;
  const minD2 = minDistTiles * minDistTiles;

  for (let ty = 2; ty <= MAP_SZ - cfg.h - 2; ty += 3) {
    for (let tx = 2; tx <= MAP_SZ - cfg.w - 2; tx += 3) {
      if (!canPlaceBuilding(tx, ty, cfg.w, cfg.h)) continue;
      const d = minDistSqToExistingHalls(tx, ty);
      if (d < minD2) continue;
      const edgeBias = Math.min(tx, ty, MAP_SZ - tx - cfg.w, MAP_SZ - ty - cfg.h) * 0.04;
      const score = d - edgeBias;
      if (score > bestScore) { bestScore = score; bestTx = tx; bestTy = ty; }
    }
  }

  if (bestTx === -1) return false;
  spawnBuilding(fId, B_HALL, bestTx, bestTy);
  return true;
}

function placeBotStarts(botCount) {
  let placed = 0;
  for (let fId = 1; fId <= botCount; fId++) {
    if (placeBotHall(fId, START_MIN_DIST_TILES)) { placed++; continue; }
    if (placeBotHall(fId, START_MIN_DIST_TILES - 4)) { placed++; continue; }
    if (placeBotHall(fId, START_MIN_DIST_TILES - 8)) placed++;
  }
  return placed;
}

function startTileFromWorld(wx, wy) {
  const cfg = BuildCfg[B_HALL];
  Temp[0] = clamp(Math.floor(wx / TILE - cfg.w * 0.5), 0, MAP_SZ - cfg.w);
  Temp[1] = clamp(Math.floor(wy / TILE - cfg.h * 0.5), 0, MAP_SZ - cfg.h);
}

function destroyBuilding(id) {
  if (!Builds.active[id]) return;
  const type = Builds.type[id];
  const fId = Builds.faction[id];
  for (let yy = 0; yy < Builds.h[id]; yy++) {
    for (let xx = 0; xx < Builds.w[id]; xx++) {
      const gx = Builds.tx[id] + xx;
      const gy = Builds.ty[id] + yy;
      if (isInsideMapTile(gx, gy) && mapGrid[gy * MAP_SZ + gx] === id) {
        mapGrid[gy * MAP_SZ + gx] = -1;
      }
    }
  }
  if (type !== B_HALL && Factions[fId].current[type] > 0) Factions[fId].current[type]--;
  if (Engine.selectedBuilding === id) Engine.selectedBuilding = -1;
  Builds.active[id] = 0;
  bFree.push(id);
}

function spawnUnit(factionId, x, y) {
  if (uFree.length === 0) return -1;
  const id = uFree.pop();
  Units.active[id] = 1;
  Units.uid[id] = ++Engine.uidGen;
  Units.faction[id] = factionId;
  Units.x[id] = x;
  Units.y[id] = y;
  Units.tx[id] = x;
  Units.ty[id] = y;
  Units.homeX[id] = x;
  Units.homeY[id] = y;
  Units.hp[id] = UnitCfg.hp;
  Units.state[id] = STATE_IDLE;
  Units.targetType[id] = 0;
  Units.targetId[id] = -1;
  Units.targetUid[id] = 0;
  Units.cooldown[id] = 0;
  Units.scanTimer[id] = (id % 5) * 0.07;
  Units.flash[id] = 0;
  Units.attackRange[id] = UnitCfg.range;
  Units.aggroRange[id] = UnitCfg.aggro;
  Units.chaseRange[id] = UnitCfg.chase;
  Units.damage[id] = UnitCfg.damage;
  Units.speed[id] = UnitCfg.speed;
  Units.visionRange[id] = UnitCfg.vision;
  Units.order[id] = ORDER_NONE;
  Units.hasWaypoint[id] = 0;
  Units.blockedTime[id] = 0;
  return id;
}

function killUnit(id) {
  if (!Units.active[id]) return;
  if (Sel.count > 0) {
    let write = 0;
    for (let i = 0; i < Sel.count; i++) {
      if (Sel.ids[i] !== id) Sel.ids[write++] = Sel.ids[i];
    }
    Sel.count = write;
  }
  Units.active[id] = 0;
  uFree.push(id);
}

function setUnitTargetUnit(uId, targetId) {
  Units.targetType[uId] = 1;
  Units.targetId[uId] = targetId;
  Units.targetUid[uId] = Units.uid[targetId];
  Units.state[uId] = STATE_ATTACK;
}

function setUnitTargetBuilding(uId, bId) {
  Units.targetType[uId] = 2;
  Units.targetId[uId] = bId;
  Units.targetUid[uId] = Builds.uid[bId];
  Units.state[uId] = STATE_ATTACK;
}

function clearWaypoint(uId) {
  Units.hasWaypoint[uId] = 0;
  Units.blockedTime[uId] = 0;
}

function clearUnitTarget(uId) {
  Units.targetType[uId] = 0;
  Units.targetId[uId] = -1;
  Units.targetUid[uId] = 0;
}

function resumeUnitOrder(uId) {
  clearUnitTarget(uId);
  clearWaypoint(uId);
  if (Units.order[uId] === ORDER_ATTACK_MOVE) Units.state[uId] = STATE_ATTACK_MOVE;
  else Units.state[uId] = STATE_IDLE;
}

function closestPointOnBuilding(bId, x, y, out) {
  const minX = Builds.tx[bId] * TILE;
  const minY = Builds.ty[bId] * TILE;
  const maxX = (Builds.tx[bId] + Builds.w[bId]) * TILE;
  const maxY = (Builds.ty[bId] + Builds.h[bId]) * TILE;
  out[0] = clamp(x, minX, maxX);
  out[1] = clamp(y, minY, maxY);
}

function distSqToBuildingFromPoint(x, y, bId) {
  closestPointOnBuilding(bId, x, y, TargetPoint);
  return distSq(x, y, TargetPoint[0], TargetPoint[1]);
}

function getTargetPoint(uId, out) {
  const tType = Units.targetType[uId];
  const tId = Units.targetId[uId];
  if (tType === 1) {
    if (!Units.active[tId] || Units.uid[tId] !== Units.targetUid[uId]) return false;
    out[0] = Units.x[tId];
    out[1] = Units.y[tId];
    return true;
  }
  if (tType === 2) {
    if (!Builds.active[tId] || Builds.uid[tId] !== Units.targetUid[uId]) return false;
    closestPointOnBuilding(tId, Units.x[uId], Units.y[uId], out);
    return true;
  }
  return false;
}

function isTargetVisibleToUnit(uId) {
  const tType = Units.targetType[uId];
  const tId = Units.targetId[uId];
  const vr = Units.visionRange[uId];
  const rr = vr * vr;
  if (tType === 1) {
    if (!Units.active[tId] || Units.uid[tId] !== Units.targetUid[uId]) return false;
    return distSq(Units.x[uId], Units.y[uId], Units.x[tId], Units.y[tId]) <= rr;
  }
  if (tType === 2) {
    if (!Builds.active[tId] || Builds.uid[tId] !== Units.targetUid[uId]) return false;
    return distSqToBuildingFromPoint(Units.x[uId], Units.y[uId], tId) <= rr;
  }
  return false;
}

function acquireVisibleTarget(uId) {
  if (!findNearestEnemy(uId, Units.visionRange[uId])) return false;
  Units.homeX[uId] = Units.x[uId];
  Units.homeY[uId] = Units.y[uId];
  clearWaypoint(uId);
  if (Temp[0] === 1) setUnitTargetUnit(uId, Temp[1]);
  else setUnitTargetBuilding(uId, Temp[1]);
  Units.state[uId] = STATE_ATTACK;
  return true;
}

function issueMoveOrder(x, y) {
  if (Sel.count === 0) return;
  const cols = Math.min(Sel.count, 6);
  const spacing = 18;
  for (let i = 0; i < Sel.count; i++) {
    const id = Sel.ids[i];
    if (!Units.active[id]) continue;
    const col = i % cols;
    const row = (i / cols) | 0;
    const ox = (col - (cols - 1) * 0.5) * spacing;
    const oy = row * spacing;
    Units.tx[id] = clamp(x + ox, 8, WORLD_SZ - 8);
    Units.ty[id] = clamp(y + oy, 8, WORLD_SZ - 8);
    Units.homeX[id] = Units.tx[id];
    Units.homeY[id] = Units.ty[id];
    Units.state[id] = STATE_MOVE;
    Units.order[id] = ORDER_MOVE;
    clearWaypoint(id);
    clearUnitTarget(id);
  }
  addPing(x, y);
}

function issueAttackMoveOrder(x, y) {
  if (Sel.count === 0) return;
  const cols = Math.min(Sel.count, 6);
  const spacing = 18;
  for (let i = 0; i < Sel.count; i++) {
    const id = Sel.ids[i];
    if (!Units.active[id]) continue;
    const col = i % cols;
    const row = (i / cols) | 0;
    const ox = (col - (cols - 1) * 0.5) * spacing;
    const oy = row * spacing;
    Units.tx[id] = clamp(x + ox, 8, WORLD_SZ - 8);
    Units.ty[id] = clamp(y + oy, 8, WORLD_SZ - 8);
    Units.homeX[id] = Units.x[id];
    Units.homeY[id] = Units.y[id];
    Units.state[id] = STATE_ATTACK_MOVE;
    Units.order[id] = ORDER_ATTACK_MOVE;
    clearWaypoint(id);
    clearUnitTarget(id);
  }
  addPing(x, y);
}

function issueAttackOrderUnit(targetId) {
  if (Sel.count === 0) return;
  for (let i = 0; i < Sel.count; i++) {
    const id = Sel.ids[i];
    if (!Units.active[id]) continue;
    Units.homeX[id] = Units.x[targetId];
    Units.homeY[id] = Units.y[targetId];
    Units.order[id] = ORDER_ATTACK;
    clearWaypoint(id);
    setUnitTargetUnit(id, targetId);
    Units.state[id] = STATE_ATTACK;
  }
  addPing(Units.x[targetId], Units.y[targetId]);
}

function issueAttackOrderBuilding(bId) {
  if (Sel.count === 0) return;
  const cx = (Builds.tx[bId] + Builds.w[bId] * 0.5) * TILE;
  const cy = (Builds.ty[bId] + Builds.h[bId] * 0.5) * TILE;
  for (let i = 0; i < Sel.count; i++) {
    const id = Sel.ids[i];
    if (!Units.active[id]) continue;
    Units.homeX[id] = cx;
    Units.homeY[id] = cy;
    Units.order[id] = ORDER_ATTACK;
    clearWaypoint(id);
    setUnitTargetBuilding(id, bId);
  }
  addPing(cx, cy);
}

function pickUnitAt(wx, wy, onlyFaction) {
  const hs = hashIndex(wx, wy);
  const hx = hs % HASH_W;
  const hy = (hs / HASH_W) | 0;
  let best = -1;
  let bestD = 999999;
  for (let yy = hy - 1; yy <= hy + 1; yy++) {
    if (yy < 0 || yy >= HASH_H) continue;
    for (let xx = hx - 1; xx <= hx + 1; xx++) {
      if (xx < 0 || xx >= HASH_W) continue;
      let n = hashHead[yy * HASH_W + xx];
      while (n !== -1) {
        if (Units.active[n] && (onlyFaction < 0 || Units.faction[n] === onlyFaction)) {
          const d = distSq(wx, wy, Units.x[n], Units.y[n]);
          if (d < 18 * 18 && d < bestD) { bestD = d; best = n; }
        }
        n = hashNext[n];
      }
    }
  }
  return best;
}

function pickEnemyUnitAt(wx, wy, myFaction) {
  const hs = hashIndex(wx, wy);
  const hx = hs % HASH_W;
  const hy = (hs / HASH_W) | 0;
  let best = -1;
  let bestD = 999999;
  for (let yy = hy - 1; yy <= hy + 1; yy++) {
    if (yy < 0 || yy >= HASH_H) continue;
    for (let xx = hx - 1; xx <= hx + 1; xx++) {
      if (xx < 0 || xx >= HASH_W) continue;
      let n = hashHead[yy * HASH_W + xx];
      while (n !== -1) {
        if (Units.active[n] && Units.faction[n] !== myFaction) {
          const d = distSq(wx, wy, Units.x[n], Units.y[n]);
          if (d < 18 * 18 && d < bestD) { bestD = d; best = n; }
        }
        n = hashNext[n];
      }
    }
  }
  return best;
}

function pickEnemyBuildingAt(wx, wy, myFaction) {
  const gx = (wx / TILE) | 0;
  const gy = (wy / TILE) | 0;
  if (!isInsideMapTile(gx, gy)) return -1;
  const bId = mapGrid[gy * MAP_SZ + gx];
  if (bId === -1) return -1;
  return Builds.faction[bId] !== myFaction ? bId : -1;
}

function findOwnBuildingAt(wx, wy, factionId) {
  const gx = (wx / TILE) | 0;
  const gy = (wy / TILE) | 0;
  if (!isInsideMapTile(gx, gy)) return -1;
  const bId = mapGrid[gy * MAP_SZ + gx];
  if (bId === -1) return -1;
  return Builds.faction[bId] === factionId ? bId : -1;
}

function rebuildHash() {
  hashHead.fill(-1);
  for (let i = 0; i < MAX_U; i++) {
    if (!Units.active[i]) continue;
    const h = hashIndex(Units.x[i], Units.y[i]);
    hashNext[i] = hashHead[h];
    hashHead[h] = i;
  }
}

function findNearestEnemy(unitId, range) {
  const ux = Units.x[unitId], uy = Units.y[unitId], uf = Units.faction[unitId];
  const rr = range * range;
  const base = hashIndex(ux, uy);
  const hx = base % HASH_W, hy = (base / HASH_W) | 0;
  const cellRadius = ((range / HASH_CELL_SIZE) | 0) + 1;
  let bestType = 0;
  let bestId = -1;
  let bestD = rr + 1;

  for (let yy = hy - cellRadius; yy <= hy + cellRadius; yy++) {
    if (yy < 0 || yy >= HASH_H) continue;
    for (let xx = hx - cellRadius; xx <= hx + cellRadius; xx++) {
      if (xx < 0 || xx >= HASH_W) continue;
      let n = hashHead[yy * HASH_W + xx];
      while (n !== -1) {
        if (n !== unitId && Units.active[n] && Units.faction[n] !== uf) {
          const d = distSq(ux, uy, Units.x[n], Units.y[n]);
          if (d < bestD && d <= rr) {
            bestD = d; bestId = n; bestType = 1;
          }
        }
        n = hashNext[n];
      }
    }
  }

  // Se não encontrou unidade, procura prédio inimigo próximo por varredura simples.
  if (bestId === -1) {
    for (let i = 0; i < MAX_B; i++) {
      if (!Builds.active[i] || Builds.faction[i] === uf) continue;
      const d = distSqToBuildingFromPoint(ux, uy, i);
      if (d < bestD && d <= rr) {
        bestD = d; bestId = i; bestType = 2;
      }
    }
  }

  Temp[0] = bestType;
  Temp[1] = bestId;
  return bestId !== -1;
}

function dealDamageToUnit(attackerId, targetId, amount) {
  if (!Units.active[targetId]) return;
  Units.hp[targetId] -= amount;
  Units.flash[targetId] = FLASH_MAX;
  Units.flash[attackerId] = FLASH_MAX * 0.55;
  if (Units.hp[targetId] <= 0) {
    killUnit(targetId);
    return;
  }
  if (Units.active[targetId] && Units.faction[targetId] !== Units.faction[attackerId]) {
    setUnitTargetUnit(targetId, attackerId);
    Units.state[targetId] = STATE_ATTACK;
    Units.homeX[targetId] = Units.x[targetId];
    Units.homeY[targetId] = Units.y[targetId];
  }
}

function dealDamageToBuilding(targetId, amount) {
  if (!Builds.active[targetId]) return;
  Builds.hp[targetId] -= amount;
  Builds.flash[targetId] = FLASH_MAX;
  if (Builds.hp[targetId] <= 0) destroyBuilding(targetId);
}

function collidesBuilding(x, y) {
  return blockedBuildingAt(x, y) !== -1;
}

function blockedBuildingAt(x, y) {
  const gx = Math.floor(x / TILE);
  const gy = Math.floor(y / TILE);
  if (!isInsideMapTile(gx, gy)) return -2;
  return mapGrid[gy * MAP_SZ + gx];
}

function isStandable(x, y) {
  return x >= 8 && y >= 8 && x <= WORLD_SZ - 8 && y <= WORLD_SZ - 8 && !collidesBuilding(x, y);
}

function trySetDetour(id, blockerId, finalX, finalY) {
  if (blockerId < 0 || !Builds.active[blockerId]) return false;
  const ux = Units.x[id];
  const uy = Units.y[id];
  let bestX = 0;
  let bestY = 0;
  let bestScore = 1e30;

  for (let ring = 0; ring <= 3; ring++) {
    const leftTx = Builds.tx[blockerId] - 1 - ring;
    const rightTx = Builds.tx[blockerId] + Builds.w[blockerId] + ring;
    const topTy = Builds.ty[blockerId] - 1 - ring;
    const bottomTy = Builds.ty[blockerId] + Builds.h[blockerId] + ring;

    for (let tx = leftTx; tx <= rightTx; tx++) {
      const x = tx * TILE + TILE * 0.5;
      const topY = topTy * TILE + TILE * 0.5;
      if (isStandable(x, topY)) {
        const fromUnit = distSq(ux, uy, x, topY);
        const score = distSq(x, topY, finalX, finalY) + fromUnit * 0.25;
        if (fromUnit > 64 && score < bestScore) { bestScore = score; bestX = x; bestY = topY; }
      }
      const bottomY = bottomTy * TILE + TILE * 0.5;
      if (isStandable(x, bottomY)) {
        const fromUnit = distSq(ux, uy, x, bottomY);
        const score = distSq(x, bottomY, finalX, finalY) + fromUnit * 0.25;
        if (fromUnit > 64 && score < bestScore) { bestScore = score; bestX = x; bestY = bottomY; }
      }
    }

    for (let ty = topTy + 1; ty < bottomTy; ty++) {
      const y = ty * TILE + TILE * 0.5;
      const leftX = leftTx * TILE + TILE * 0.5;
      if (isStandable(leftX, y)) {
        const fromUnit = distSq(ux, uy, leftX, y);
        const score = distSq(leftX, y, finalX, finalY) + fromUnit * 0.25;
        if (fromUnit > 64 && score < bestScore) { bestScore = score; bestX = leftX; bestY = y; }
      }
      const rightX = rightTx * TILE + TILE * 0.5;
      if (isStandable(rightX, y)) {
        const fromUnit = distSq(ux, uy, rightX, y);
        const score = distSq(rightX, y, finalX, finalY) + fromUnit * 0.25;
        if (fromUnit > 64 && score < bestScore) { bestScore = score; bestX = rightX; bestY = y; }
      }
    }
  }

  if (bestScore >= 1e29) return false;
  Units.hasWaypoint[id] = 1;
  Units.wayX[id] = bestX;
  Units.wayY[id] = bestY;
  Units.blockedTime[id] = 0;
  return true;
}

function findSpawnPointAroundBuilding(bId, out) {
  const centerX = (Builds.tx[bId] + Builds.w[bId] * 0.5) * TILE;
  const centerY = (Builds.ty[bId] + Builds.h[bId] * 0.5) * TILE;
  for (let ring = 0; ring <= 5; ring++) {
    const belowY = (Builds.ty[bId] + Builds.h[bId] + ring) * TILE + TILE * 0.5;
    if (isStandable(centerX, belowY)) { out[0] = centerX; out[1] = belowY; return true; }

    const rightX = (Builds.tx[bId] + Builds.w[bId] + ring) * TILE + TILE * 0.5;
    if (isStandable(rightX, centerY)) { out[0] = rightX; out[1] = centerY; return true; }

    const leftX = (Builds.tx[bId] - 1 - ring) * TILE + TILE * 0.5;
    if (isStandable(leftX, centerY)) { out[0] = leftX; out[1] = centerY; return true; }

    const aboveY = (Builds.ty[bId] - 1 - ring) * TILE + TILE * 0.5;
    if (isStandable(centerX, aboveY)) { out[0] = centerX; out[1] = aboveY; return true; }

    const leftTx = Builds.tx[bId] - 1 - ring;
    const rightTx = Builds.tx[bId] + Builds.w[bId] + ring;
    const topTy = Builds.ty[bId] - 1 - ring;
    const bottomTy = Builds.ty[bId] + Builds.h[bId] + ring;
    for (let tx = leftTx; tx <= rightTx; tx++) {
      const x = tx * TILE + TILE * 0.5;
      const topY = topTy * TILE + TILE * 0.5;
      if (isStandable(x, topY)) { out[0] = x; out[1] = topY; return true; }
      const bottomY = bottomTy * TILE + TILE * 0.5;
      if (isStandable(x, bottomY)) { out[0] = x; out[1] = bottomY; return true; }
    }
    for (let ty = topTy + 1; ty < bottomTy; ty++) {
      const y = ty * TILE + TILE * 0.5;
      const leftX = leftTx * TILE + TILE * 0.5;
      if (isStandable(leftX, y)) { out[0] = leftX; out[1] = y; return true; }
      const rightX = rightTx * TILE + TILE * 0.5;
      if (isStandable(rightX, y)) { out[0] = rightX; out[1] = y; return true; }
    }
  }
  return false;
}

function moveUnitStep(id, dt, targetX, targetY) {
  let moveX = targetX;
  let moveY = targetY;
  if (Units.hasWaypoint[id]) {
    const wdx = Units.wayX[id] - Units.x[id];
    const wdy = Units.wayY[id] - Units.y[id];
    if (wdx * wdx + wdy * wdy < 36) {
      clearWaypoint(id);
    } else {
      moveX = Units.wayX[id];
      moveY = Units.wayY[id];
    }
  }

  let dx = moveX - Units.x[id];
  let dy = moveY - Units.y[id];
  const d2 = dx * dx + dy * dy;
  if (d2 < 4) {
    if (Units.hasWaypoint[id]) {
      clearWaypoint(id);
      return false;
    }
    return true;
  }
  const d = Math.sqrt(d2);
  const step = Units.speed[id] * dt;
  const nx = Units.x[id] + (dx / d) * step;
  const ny = Units.y[id] + (dy / d) * step;
  let blocker = blockedBuildingAt(nx, ny);

  if (blocker === -1) {
    Units.x[id] = clamp(nx, 8, WORLD_SZ - 8);
    Units.y[id] = clamp(ny, 8, WORLD_SZ - 8);
    Units.blockedTime[id] = 0;
  } else {
    const blockX = blockedBuildingAt(nx, Units.y[id]);
    const blockY = blockedBuildingAt(Units.x[id], ny);
    if (blockX === -1) {
      Units.x[id] = clamp(nx, 8, WORLD_SZ - 8);
      Units.blockedTime[id] = 0;
    } else if (blockY === -1) {
      Units.y[id] = clamp(ny, 8, WORLD_SZ - 8);
      Units.blockedTime[id] = 0;
    } else {
      Units.blockedTime[id] += dt;
      if (blocker < 0) blocker = blockX >= 0 ? blockX : blockY;
      if (Units.blockedTime[id] > 0.08 || !Units.hasWaypoint[id]) {
        if (!trySetDetour(id, blocker, targetX, targetY)) Units.blockedTime[id] = 0;
      }
    }
  }
  return !Units.hasWaypoint[id] && distSq(Units.x[id], Units.y[id], targetX, targetY) < 4;
}

function updateUnits(dt) {
  for (let i = 0; i < MAX_U; i++) {
    if (!Units.active[i]) continue;

    if (Units.cooldown[i] > 0) Units.cooldown[i] -= dt;
    if (Units.cooldown[i] < 0) Units.cooldown[i] = 0;
    if (Units.scanTimer[i] > 0) Units.scanTimer[i] -= dt;
    if (Units.flash[i] > 0) Units.flash[i] -= dt;

    // Auto aquisição de alvo se estiver ocioso ou se estiver movendo e um inimigo entrou em alcance.
    if ((Units.state[i] === STATE_IDLE || Units.state[i] === STATE_MOVE || Units.state[i] === STATE_ATTACK_MOVE) && Units.scanTimer[i] <= 0) {
      Units.scanTimer[i] = RETARGET_INTERVAL + (i % 3) * 0.03;
      acquireVisibleTarget(i);
    }

    if (Units.state[i] === STATE_MOVE) {
      const arrived = moveUnitStep(i, dt, Units.tx[i], Units.ty[i]);
      if (arrived) {
        Units.state[i] = STATE_IDLE;
        Units.order[i] = ORDER_NONE;
      }
      continue;
    }

    if (Units.state[i] === STATE_ATTACK_MOVE) {
      const arrived = moveUnitStep(i, dt, Units.tx[i], Units.ty[i]);
      if (arrived) {
        Units.state[i] = STATE_IDLE;
        Units.order[i] = ORDER_NONE;
      }
      continue;
    }

    if (Units.state[i] === STATE_ATTACK || Units.state[i] === STATE_CHASE) {
      if (!getTargetPoint(i, TargetPoint)) {
        resumeUnitOrder(i);
        continue;
      }

      if (Units.order[i] !== ORDER_ATTACK && !isTargetVisibleToUnit(i)) {
        resumeUnitOrder(i);
        continue;
      }

      const tx = TargetPoint[0], ty = TargetPoint[1];
      const d2 = distSq(Units.x[i], Units.y[i], tx, ty);
      const attackR2 = Units.attackRange[i] * Units.attackRange[i];
      const chaseR2 = Units.chaseRange[i] * Units.chaseRange[i];
      const homeD2 = distSq(Units.homeX[i], Units.homeY[i], tx, ty);

      if (homeD2 > chaseR2) {
        resumeUnitOrder(i);
        continue;
      }

      if (d2 <= attackR2) {
        Units.state[i] = STATE_ATTACK;
        if (Units.cooldown[i] <= 0) {
          if (Units.targetType[i] === 1) dealDamageToUnit(i, Units.targetId[i], Units.damage[i]);
          else if (Units.targetType[i] === 2) dealDamageToBuilding(Units.targetId[i], Units.damage[i]);
          Units.cooldown[i] = UnitCfg.cooldown;
        }
      } else {
        Units.state[i] = STATE_CHASE;
        moveUnitStep(i, dt, tx, ty);
      }
      continue;
    }
  }
}

function updateBuildingFeedback(dt) {
  for (let i = 0; i < MAX_B; i++) {
    if (Builds.active[i] && Builds.flash[i] > 0) Builds.flash[i] -= dt;
  }
}

function updateEconomy(dt) {
  Engine.econAcc += dt;
  if (Engine.econAcc < ECON_INTERVAL) return;
  Engine.econAcc -= ECON_INTERVAL;

  for (let i = 0; i < MAX_B; i++) {
    if (!Builds.active[i]) continue;
    const f = Factions[Builds.faction[i]];
    const inc = BuildCfg[Builds.type[i]].income;
    f.wood += inc[0];
    f.stone += inc[1];
    f.grain += inc[2];
  }
  UI.updateRes();
}

function queueUnitFromBarracks(bId) {
  if (!Builds.active[bId] || Builds.type[bId] !== B_BARR) return false;
  const f = Factions[Builds.faction[bId]];
  if (Builds.queueCount[bId] >= MAX_TRAIN_QUEUE) return false;
  if (!canTrainUnit(Builds.faction[bId])) return false;
  if (f.grain < UnitCfg.grainCost) return false;
  f.grain -= UnitCfg.grainCost;
  Builds.queueCount[bId]++;
  if (Builds.queue[bId] <= 0) Builds.queue[bId] = TRAIN_TIME;
  if (Builds.faction[bId] === 0) UI.updateRes();
  return true;
}

function updateProduction(dt) {
  for (let i = 0; i < MAX_B; i++) {
    if (!Builds.active[i] || Builds.type[i] !== B_BARR || Builds.queueCount[i] === 0) continue;
    Builds.queue[i] -= dt;
    if (Builds.queue[i] <= 0) {
      const fId = Builds.faction[i];
      if (!canTrainUnit(fId)) {
        Factions[fId].grain += UnitCfg.grainCost;
        if (Builds.queueCount[i] > 0) Builds.queueCount[i]--;
        if (fId === 0) {
          UI.updateRes();
          UI.msg('Limite de unidades atingido.', true);
        }
        Builds.queue[i] = Builds.queueCount[i] > 0 ? TRAIN_TIME : 0;
        continue;
      }
      if (!findSpawnPointAroundBuilding(i, SpawnPoint)) {
        Factions[fId].grain += UnitCfg.grainCost;
        if (fId === 0) {
          UI.updateRes();
          UI.msg('Sem espaço livre para a unidade.', true);
        }
        if (Builds.queueCount[i] > 0) Builds.queueCount[i]--;
        Builds.queue[i] = Builds.queueCount[i] > 0 ? TRAIN_TIME : 0;
        continue;
      }
      const u = spawnUnit(fId, SpawnPoint[0], SpawnPoint[1]);
      if (u === -1) {
        Factions[fId].grain += UnitCfg.grainCost;
        if (fId === 0) {
          UI.updateRes();
          UI.msg('Não foi possível criar a unidade.', true);
        }
        if (Builds.queueCount[i] > 0) Builds.queueCount[i]--;
        Builds.queue[i] = Builds.queueCount[i] > 0 ? TRAIN_TIME : 0;
        continue;
      }
      Units.homeX[u] = Units.x[u];
      Units.homeY[u] = Units.y[u];
      if (Builds.queueCount[i] > 0) Builds.queueCount[i]--;
      Builds.queue[i] = Builds.queueCount[i] > 0 ? TRAIN_TIME : 0;
    }
  }
}

function updatePings(dt) {
  for (let i = 0; i < Pings.count; i++) {
    Pings.t[i] -= dt;
    if (Pings.t[i] <= 0) {
      for (let j = i; j < Pings.count - 1; j++) {
        Pings.x[j] = Pings.x[j + 1];
        Pings.y[j] = Pings.y[j + 1];
        Pings.t[j] = Pings.t[j + 1];
      }
      Pings.count--;
      i--;
    }
  }
}

function countUnitsByFaction(fId) {
  let c = 0;
  for (let i = 0; i < MAX_U; i++) if (Units.active[i] && Units.faction[i] === fId) c++;
  return c;
}

function canTrainUnit(fId) {
  return uFree.length > 0 && countUnitsByFaction(fId) < UNIT_CAP;
}

function findBuildingOfType(fId, type) {
  for (let i = 0; i < MAX_B; i++) if (Builds.active[i] && Builds.faction[i] === fId && Builds.type[i] === type) return i;
  return -1;
}

function findHall(fId) {
  return findBuildingOfType(fId, B_HALL);
}

function findVisibleEnemyForFaction(fId) {
  for (let i = 0; i < MAX_U; i++) {
    if (!Units.active[i] || Units.faction[i] !== fId) continue;
    if (findNearestEnemy(i, Units.visionRange[i])) return true;
  }

  let bestType = 0;
  let bestId = -1;
  let bestD = 1e30;
  for (let b = 0; b < MAX_B; b++) {
    if (!Builds.active[b] || Builds.faction[b] !== fId) continue;
    const cx = (Builds.tx[b] + Builds.w[b] * 0.5) * TILE;
    const cy = (Builds.ty[b] + Builds.h[b] * 0.5) * TILE;
    const vr = BuildCfg[Builds.type[b]].vision || 0;
    const rr = vr * vr;

    for (let u = 0; u < MAX_U; u++) {
      if (!Units.active[u] || Units.faction[u] === fId) continue;
      const d = distSq(cx, cy, Units.x[u], Units.y[u]);
      if (d <= rr && d < bestD) { bestD = d; bestType = 1; bestId = u; }
    }

    for (let eb = 0; eb < MAX_B; eb++) {
      if (!Builds.active[eb] || Builds.faction[eb] === fId) continue;
      const d = distSqToBuildingFromPoint(cx, cy, eb);
      if (d <= rr && d < bestD) { bestD = d; bestType = 2; bestId = eb; }
    }
  }

  Temp[0] = bestType;
  Temp[1] = bestId;
  return bestId !== -1;
}

function tryBuildForFaction(fId, type, nearTx, nearTy, radius) {
  const cfg = BuildCfg[type];
  const f = Factions[fId];
  if (type !== B_HALL && f.current[type] >= f.limits[type]) return false;
  if (bFree.length === 0) return false;
  if (!canAfford(fId, type)) return false;
  for (let r = 1; r <= radius; r++) {
    for (let dy = -r; dy <= r; dy++) {
      for (let dx = -r; dx <= r; dx++) {
        const tx = nearTx + dx;
        const ty = nearTy + dy;
        if (canPlaceBuilding(tx, ty, cfg.w, cfg.h)) {
          payForBuild(fId, type);
          const b = spawnBuilding(fId, type, tx, ty);
          if (b !== -1) {
            if (fId === 0) {
              UI.updateRes();
              UI.updateLimits();
            }
            return true;
          }
        }
      }
    }
  }
  return false;
}

function orderFactionAttackMove(fId, x, y) {
  let count = 0;
  for (let i = 0; i < MAX_U; i++) {
    if (!Units.active[i] || Units.faction[i] !== fId) continue;
    const col = count % 6;
    const row = (count / 6) | 0;
    Units.tx[i] = clamp(x + (col - 2.5) * 18, 8, WORLD_SZ - 8);
    Units.ty[i] = clamp(y + row * 18, 8, WORLD_SZ - 8);
    Units.homeX[i] = Units.x[i];
    Units.homeY[i] = Units.y[i];
    Units.order[i] = ORDER_ATTACK_MOVE;
    Units.state[i] = STATE_ATTACK_MOVE;
    clearWaypoint(i);
    clearUnitTarget(i);
    count++;
  }
}

function orderFactionAttackVisible(fId, targetType, targetId) {
  let tx = 0;
  let ty = 0;
  if (targetType === 1) {
    if (!Units.active[targetId]) return;
    tx = Units.x[targetId];
    ty = Units.y[targetId];
  } else if (targetType === 2) {
    if (!Builds.active[targetId]) return;
    tx = (Builds.tx[targetId] + Builds.w[targetId] * 0.5) * TILE;
    ty = (Builds.ty[targetId] + Builds.h[targetId] * 0.5) * TILE;
  } else {
    return;
  }

  for (let i = 0; i < MAX_U; i++) {
    if (!Units.active[i] || Units.faction[i] !== fId) continue;
    Units.tx[i] = tx;
    Units.ty[i] = ty;
    Units.homeX[i] = Units.x[i];
    Units.homeY[i] = Units.y[i];
    Units.order[i] = ORDER_ATTACK_MOVE;
    clearWaypoint(i);
    if (targetType === 1) setUnitTargetUnit(i, targetId);
    else setUnitTargetBuilding(i, targetId);
  }
}

function chooseBotScoutPoint(fId) {
  const f = Factions[fId];
  const slot = (f.aiPhase + fId) % 6;
  f.aiPhase++;
  if (slot === 0) { Temp[0] = WORLD_SZ * 0.5; Temp[1] = WORLD_SZ * 0.5; }
  else if (slot === 1) { Temp[0] = WORLD_SZ * 0.25; Temp[1] = WORLD_SZ * 0.5; }
  else if (slot === 2) { Temp[0] = WORLD_SZ * 0.75; Temp[1] = WORLD_SZ * 0.5; }
  else if (slot === 3) { Temp[0] = WORLD_SZ * 0.5; Temp[1] = WORLD_SZ * 0.25; }
  else if (slot === 4) { Temp[0] = WORLD_SZ * 0.5; Temp[1] = WORLD_SZ * 0.75; }
  else { Temp[0] = WORLD_SZ * 0.5; Temp[1] = WORLD_SZ * 0.5; }
}

function updateBots(dt) {
  if (Engine.placingStart) return;
  Engine.botAcc += dt;
  if (Engine.botAcc < BOT_INTERVAL) return;
  Engine.botAcc -= BOT_INTERVAL;

  for (let fId = 1; fId < Factions.length; fId++) {
    const f = Factions[fId];
    if (!f.isAI) continue;
    if (f.aiAttackCooldown > 0) f.aiAttackCooldown -= BOT_INTERVAL;
    if (f.aiTrainCooldown > 0) f.aiTrainCooldown -= BOT_INTERVAL;

    const hall = findHall(fId);
    if (hall === -1) continue;
    const baseTx = Builds.tx[hall];
    const baseTy = Builds.ty[hall];

    // Fase 1: economia até limites
    if (f.current[B_MINE] < f.limits[B_MINE]) {
      if (tryBuildForFaction(fId, B_MINE, baseTx + 4, baseTy + 1, 10)) continue;
    }
    if (f.current[B_WOOD] < f.limits[B_WOOD]) {
      if (tryBuildForFaction(fId, B_WOOD, baseTx - 4, baseTy + 1, 10)) continue;
    }
    if (f.current[B_FARM] < f.limits[B_FARM]) {
      if (tryBuildForFaction(fId, B_FARM, baseTx, baseTy + 6, 12)) continue;
    }

    // Fase 2: quartel e produção
    if (f.current[B_BARR] < f.limits[B_BARR]) {
      if (tryBuildForFaction(fId, B_BARR, baseTx + 5, baseTy - 4, 10)) continue;
    }

    const army = countUnitsByFaction(fId);
    const barr = findBuildingOfType(fId, B_BARR);
    if (barr !== -1 && f.aiTrainCooldown <= 0 && army < BOT_ARMY_SOFT_CAP) {
      if (queueUnitFromBarracks(barr)) f.aiTrainCooldown = BOT_TRAIN_DELAY;
      else f.aiTrainCooldown = 1.5;
    }

    // Fase 3: ataque com número mínimo de unidades
    if (army >= BOT_ATTACK_MIN_ARMY && f.aiAttackCooldown <= 0) {
      if (findVisibleEnemyForFaction(fId)) orderFactionAttackVisible(fId, Temp[0], Temp[1]);
      else {
        chooseBotScoutPoint(fId);
        orderFactionAttackMove(fId, Temp[0], Temp[1]);
      }
      f.aiAttackCooldown = BOT_ATTACK_COOLDOWN;
    }
  }
}

function checkGameOver() {
  if (!Engine.running || Factions.length === 0) return;
  if (Engine.placingStart) return;
  if (findHall(0) === -1) {
    Game.end(false);
    return;
  }
  for (let fId = 1; fId < Factions.length; fId++) {
    if (findHall(fId) !== -1) return;
  }
  Game.end(true);
}

function buildingFill(type, enemy) {
  if (enemy) {
    if (type === B_HALL) return '#7b4835';
    if (type === B_BARR) return '#723e4a';
    if (type === B_MINE) return '#5f4b52';
    if (type === B_WOOD) return '#6b4b30';
    if (type === B_FARM) return '#6c6430';
    return '#6c3535';
  }
  if (type === B_HALL) return '#6d623e';
  if (type === B_BARR) return '#4b5068';
  if (type === B_MINE) return '#4c4f55';
  if (type === B_WOOD) return '#5e4a2d';
  if (type === B_FARM) return '#6c7136';
  return '#38473d';
}

function buildingAccent(type, enemy) {
  if (enemy) return type === B_FARM ? '#d1b44a' : '#dc8a74';
  if (type === B_MINE) return '#aab0ba';
  if (type === B_WOOD) return '#d39b55';
  if (type === B_FARM) return '#e5d160';
  if (type === B_BARR) return '#a6b4da';
  return '#d8aa72';
}

function drawBuildingDetails(id, x, y, w, h) {
  const type = Builds.type[id];
  const enemy = Builds.faction[id] !== 0;
  const accent = buildingAccent(type, enemy);
  ctx.strokeStyle = accent;
  ctx.fillStyle = accent;
  ctx.lineWidth = 2 / Engine.cam.z;

  if (type === B_HALL) {
    ctx.beginPath();
    ctx.moveTo(x + w * 0.18, y + h * 0.42);
    ctx.lineTo(x + w * 0.5, y + h * 0.16);
    ctx.lineTo(x + w * 0.82, y + h * 0.42);
    ctx.stroke();
    ctx.fillRect(x + w * 0.42, y + h * 0.58, w * 0.16, h * 0.3);
    ctx.fillRect(x + w * 0.68, y + h * 0.12, w * 0.06, h * 0.24);
  } else if (type === B_MINE) {
    ctx.fillStyle = enemy ? '#2b1d20' : '#20252a';
    ctx.fillRect(x + w * 0.26, y + h * 0.3, w * 0.48, h * 0.48);
    ctx.strokeStyle = accent;
    ctx.beginPath();
    ctx.moveTo(x + w * 0.2, y + h * 0.28);
    ctx.lineTo(x + w * 0.5, y + h * 0.12);
    ctx.lineTo(x + w * 0.8, y + h * 0.28);
    ctx.stroke();
  } else if (type === B_WOOD) {
    for (let k = 0; k < 3; k++) {
      const ly = y + h * (0.28 + k * 0.2);
      ctx.fillRect(x + w * 0.18, ly, w * 0.64, 4 / Engine.cam.z);
    }
    ctx.strokeRect(x + w * 0.2, y + h * 0.2, w * 0.6, h * 0.6);
  } else if (type === B_FARM) {
    ctx.strokeStyle = accent;
    for (let k = 1; k < 4; k++) {
      const px = x + (w * k) / 4;
      ctx.beginPath();
      ctx.moveTo(px, y + h * 0.15);
      ctx.lineTo(px - w * 0.18, y + h * 0.85);
      ctx.stroke();
    }
  } else if (type === B_BARR) {
    ctx.strokeStyle = accent;
    ctx.strokeRect(x + w * 0.2, y + h * 0.2, w * 0.6, h * 0.6);
    ctx.beginPath();
    ctx.moveTo(x + w * 0.32, y + h * 0.34);
    ctx.lineTo(x + w * 0.68, y + h * 0.66);
    ctx.moveTo(x + w * 0.68, y + h * 0.34);
    ctx.lineTo(x + w * 0.32, y + h * 0.66);
    ctx.stroke();
  }
}

function drawMinimap() {
  layoutMinimap();
  const x = Engine.mini.x;
  const y = Engine.mini.y;
  const s = Engine.mini.size;
  const scale = s / WORLD_SZ;

  ctx.save();
  ctx.fillStyle = 'rgba(8, 12, 10, 0.82)';
  ctx.fillRect(x, y, s, s);
  ctx.strokeStyle = 'rgba(230,230,230,0.72)';
  ctx.lineWidth = 1;
  ctx.strokeRect(x, y, s, s);
  ctx.beginPath();
  ctx.rect(x, y, s, s);
  ctx.clip();

  for (let i = 0; i < MAX_B; i++) {
    if (!Builds.active[i]) continue;
    ctx.fillStyle = buildingAccent(Builds.type[i], Builds.faction[i] !== 0);
    ctx.fillRect(x + Builds.tx[i] * TILE * scale, y + Builds.ty[i] * TILE * scale, Math.max(2, Builds.w[i] * TILE * scale), Math.max(2, Builds.h[i] * TILE * scale));
  }

  for (let i = 0; i < MAX_U; i++) {
    if (!Units.active[i]) continue;
    ctx.fillStyle = factionColor(Units.faction[i]);
    ctx.fillRect(x + Units.x[i] * scale - 1, y + Units.y[i] * scale - 1, 2, 2);
  }

  const viewW = canvas.width / Engine.cam.z * scale;
  const viewH = canvas.height / Engine.cam.z * scale;
  ctx.strokeStyle = '#ffffff';
  ctx.strokeRect(x + (Engine.cam.x - canvas.width * 0.5 / Engine.cam.z) * scale, y + (Engine.cam.y - canvas.height * 0.5 / Engine.cam.z) * scale, viewW, viewH);
  ctx.restore();
}

function render() {
  ctx.fillStyle = '#17201b';
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  ctx.save();
  ctx.translate(canvas.width * 0.5, canvas.height * 0.5);
  ctx.scale(Engine.cam.z, Engine.cam.z);
  ctx.translate(-Engine.cam.x, -Engine.cam.y);

  // Grid
  ctx.strokeStyle = '#243029';
  ctx.lineWidth = 1 / Engine.cam.z;
  const viewLeft = Engine.cam.x - canvas.width * 0.5 / Engine.cam.z;
  const viewRight = Engine.cam.x + canvas.width * 0.5 / Engine.cam.z;
  const viewTop = Engine.cam.y - canvas.height * 0.5 / Engine.cam.z;
  const viewBottom = Engine.cam.y + canvas.height * 0.5 / Engine.cam.z;
  const startX = Math.max(0, Math.floor(viewLeft / TILE) * TILE);
  const endX = Math.min(WORLD_SZ, Math.ceil(viewRight / TILE) * TILE);
  const startY = Math.max(0, Math.floor(viewTop / TILE) * TILE);
  const endY = Math.min(WORLD_SZ, Math.ceil(viewBottom / TILE) * TILE);
  for (let i = startX; i <= endX; i += TILE) {
    ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, WORLD_SZ); ctx.stroke();
  }
  for (let i = startY; i <= endY; i += TILE) {
    ctx.beginPath(); ctx.moveTo(0, i); ctx.lineTo(WORLD_SZ, i); ctx.stroke();
  }

  // Prédios
  for (let i = 0; i < MAX_B; i++) {
    if (!Builds.active[i]) continue;
    const x = Builds.tx[i] * TILE;
    const y = Builds.ty[i] * TILE;
    const w = Builds.w[i] * TILE;
    const h = Builds.h[i] * TILE;

    ctx.fillStyle = buildingFill(Builds.type[i], Builds.faction[i] !== 0);
    ctx.fillRect(x, y, w, h);
    ctx.strokeStyle = '#0b0b0b';
    ctx.lineWidth = 1.25 / Engine.cam.z;
    ctx.strokeRect(x, y, w, h);
    drawBuildingDetails(i, x, y, w, h);

    if (Builds.flash[i] > 0) {
      const a = Builds.flash[i] / FLASH_MAX;
      ctx.fillStyle = `rgba(255,235,170,${0.32 * a})`;
      ctx.fillRect(x, y, w, h);
      ctx.strokeStyle = `rgba(255,95,70,${0.85 * a})`;
      ctx.lineWidth = 3 / Engine.cam.z;
      ctx.strokeRect(x - 2, y - 2, w + 4, h + 4);
    }

    const hpMax = BuildCfg[Builds.type[i]].hp;
    const barW = w - 8;
    const ratio = Math.max(0, Builds.hp[i] / hpMax);
    ctx.fillStyle = '#111';
    ctx.fillRect(x + 4, y - 7, barW, 4);
    ctx.fillStyle = '#7fde8a';
    ctx.fillRect(x + 4, y - 7, barW * ratio, 4);

    if (Engine.selectedBuilding === i) {
      ctx.strokeStyle = '#ffffff';
      ctx.lineWidth = 2 / Engine.cam.z;
      ctx.strokeRect(x - 2, y - 2, w + 4, h + 4);
    }

    if (Builds.type[i] === B_BARR && Builds.queueCount[i] > 0) {
      ctx.fillStyle = 'rgba(255,255,255,0.9)';
      ctx.font = `${12 / Engine.cam.z}px system-ui`;
      ctx.textAlign = 'center';
      ctx.fillText(`Fila ${Builds.queueCount[i]}`, x + w * 0.5, y + h * 0.5 + 4 / Engine.cam.z);
    }
  }

  // Unidades
  for (let i = 0; i < MAX_U; i++) {
    if (!Units.active[i]) continue;
    ctx.fillStyle = factionColor(Units.faction[i]);
    ctx.beginPath(); ctx.arc(Units.x[i], Units.y[i], UnitCfg.hitRadius, 0, Math.PI * 2); ctx.fill();
    ctx.strokeStyle = '#111';
    ctx.lineWidth = 1 / Engine.cam.z;
    ctx.stroke();

    if (Units.state[i] === STATE_ATTACK || Units.state[i] === STATE_CHASE) {
      const pulse = 0.45 + 0.25 * Math.sin(Engine.pulse * 8 + i);
      ctx.strokeStyle = `rgba(255,176,76,${pulse})`;
      ctx.lineWidth = 2 / Engine.cam.z;
      ctx.beginPath(); ctx.arc(Units.x[i], Units.y[i], 13 + pulse * 2, 0, Math.PI * 2); ctx.stroke();
      if (getTargetPoint(i, TargetPoint)) {
        ctx.strokeStyle = `rgba(255,92,70,${0.22 + pulse * 0.25})`;
        ctx.lineWidth = 1 / Engine.cam.z;
        ctx.beginPath(); ctx.moveTo(Units.x[i], Units.y[i]); ctx.lineTo(TargetPoint[0], TargetPoint[1]); ctx.stroke();
      }
    }

    if (Units.flash[i] > 0) {
      const a = Units.flash[i] / FLASH_MAX;
      ctx.fillStyle = `rgba(255,245,190,${0.75 * a})`;
      ctx.beginPath(); ctx.arc(Units.x[i], Units.y[i], UnitCfg.hitRadius + 2, 0, Math.PI * 2); ctx.fill();
    }

    const hpRatio = Math.max(0, Units.hp[i] / UnitCfg.hp);
    ctx.fillStyle = '#111';
    ctx.fillRect(Units.x[i] - 10, Units.y[i] - 16, 20, 3);
    ctx.fillStyle = '#78df88';
    ctx.fillRect(Units.x[i] - 10, Units.y[i] - 16, 20 * hpRatio, 3);

    let selected = false;
    for (let k = 0; k < Sel.count; k++) if (Sel.ids[k] === i) { selected = true; break; }
    if (selected) {
      ctx.strokeStyle = '#fff';
      ctx.lineWidth = 2 / Engine.cam.z;
      ctx.beginPath(); ctx.arc(Units.x[i], Units.y[i], 11, 0, Math.PI * 2); ctx.stroke();
    }
  }

  // Preview de construção
  if (Engine.buildType !== 0) {
    const cfg = BuildCfg[Engine.buildType];
    const gx = (Engine.drag.wx / TILE) | 0;
    const gy = (Engine.drag.wy / TILE) | 0;
    const ok = canPlaceBuilding(gx, gy, cfg.w, cfg.h) && canAfford(0, Engine.buildType) && Factions[0].current[Engine.buildType] < Factions[0].limits[Engine.buildType];
    ctx.fillStyle = ok ? 'rgba(0,255,100,0.28)' : 'rgba(255,0,0,0.28)';
    ctx.fillRect(gx * TILE, gy * TILE, cfg.w * TILE, cfg.h * TILE);
  }

  if (Engine.placingStart) {
    const cfg = BuildCfg[B_HALL];
    const px = Engine.drag.active ? Engine.drag.wx : Engine.cam.x;
    const py = Engine.drag.active ? Engine.drag.wy : Engine.cam.y;
    startTileFromWorld(px, py);
    const gx = Temp[0] | 0;
    const gy = Temp[1] | 0;
    const ok = canPlaceBuilding(gx, gy, cfg.w, cfg.h);
    ctx.fillStyle = ok ? 'rgba(216,170,114,0.28)' : 'rgba(255,0,0,0.28)';
    ctx.fillRect(gx * TILE, gy * TILE, cfg.w * TILE, cfg.h * TILE);
    ctx.strokeStyle = ok ? 'rgba(255,240,190,0.95)' : 'rgba(255,90,90,0.95)';
    ctx.lineWidth = 2 / Engine.cam.z;
    ctx.strokeRect(gx * TILE, gy * TILE, cfg.w * TILE, cfg.h * TILE);
  }

  // Caixa de seleção
  if (Engine.drag.active && Engine.drag.mode === 3) {
    const x = Math.min(Engine.drag.boxX0, Engine.drag.boxX1);
    const y = Math.min(Engine.drag.boxY0, Engine.drag.boxY1);
    const w = Math.abs(Engine.drag.boxX1 - Engine.drag.boxX0);
    const h = Math.abs(Engine.drag.boxY1 - Engine.drag.boxY0);
    ctx.fillStyle = 'rgba(150,200,255,0.18)';
    ctx.strokeStyle = 'rgba(210,235,255,0.85)';
    ctx.lineWidth = 1.5 / Engine.cam.z;
    ctx.fillRect(x, y, w, h);
    ctx.strokeRect(x, y, w, h);
  }

  // Pings
  for (let i = 0; i < Pings.count; i++) {
    const alpha = Pings.t[i] / 0.4;
    const radius = (1 - alpha) * 28 + 8;
    ctx.strokeStyle = `rgba(255,255,255,${alpha})`;
    ctx.lineWidth = 2 / Engine.cam.z;
    ctx.beginPath(); ctx.arc(Pings.x[i], Pings.y[i], radius, 0, Math.PI * 2); ctx.stroke();
  }

  ctx.restore();
  if (Engine.placingStart) {
    ctx.fillStyle = 'rgba(0,0,0,0.68)';
    ctx.fillRect(canvas.width * 0.5 - 150, 82, 300, 34);
    ctx.fillStyle = '#f2ddb8';
    ctx.font = '13px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText('Escolha onde construir sua prefeitura', canvas.width * 0.5, 104);
  }
  drawMinimap();
}

function screenToWorldUpdate(e) {
  toWorld(e.clientX, e.clientY);
  Engine.drag.wx = Temp[0];
  Engine.drag.wy = Temp[1];
}

function finalizeSelectionBox() {
  const x0 = Math.min(Engine.drag.boxX0, Engine.drag.boxX1);
  const y0 = Math.min(Engine.drag.boxY0, Engine.drag.boxY1);
  const x1 = Math.max(Engine.drag.boxX0, Engine.drag.boxX1);
  const y1 = Math.max(Engine.drag.boxY0, Engine.drag.boxY1);
  Sel.count = 0;
  Engine.selectedBuilding = -1;
  for (let i = 0; i < MAX_U && Sel.count < MAX_SELECTION; i++) {
    if (!Units.active[i] || Units.faction[i] !== 0) continue;
    if (Units.x[i] >= x0 && Units.x[i] <= x1 && Units.y[i] >= y0 && Units.y[i] <= y1) {
      Sel.ids[Sel.count++] = i;
    }
  }
  UI.updateSelectionInfo();
}

function issueCommandAt(wx, wy) {
  if (Sel.count === 0) return;
  const enemyUnit = pickEnemyUnitAt(wx, wy, 0);
  const enemyBuilding = pickEnemyBuildingAt(wx, wy, 0);
  if (enemyUnit !== -1 && Units.faction[enemyUnit] !== 0) issueAttackOrderUnit(enemyUnit);
  else if (enemyBuilding !== -1) issueAttackOrderBuilding(enemyBuilding);
  else issueMoveOrder(wx, wy);
}

function handlePrimaryTap(wx, wy, pointerType) {
  const ownUnit = pickUnitAt(wx, wy, 0);
  const ownBuilding = findOwnBuildingAt(wx, wy, 0);

  if (ownUnit !== -1) {
    setSingleSelection(ownUnit);
  } else if (ownBuilding !== -1) {
    selectBuilding(ownBuilding);
  } else if (pointerType !== 'mouse' && Sel.count > 0) {
    issueCommandAt(wx, wy);
  } else {
    clearSelection();
  }
}

function resetDrag() {
  Engine.drag.active = false;
  Engine.drag.pointerId = -1;
  Engine.drag.pointerType = '';
  Engine.drag.button = 0;
  Engine.drag.mode = 0;
}

canvas.addEventListener('pointerdown', (e) => {
  if (Engine.drag.active || e.isPrimary === false) return;
  e.preventDefault();
  canvas.setPointerCapture(e.pointerId);
  Engine.drag.active = true;
  Engine.drag.pointerId = e.pointerId;
  Engine.drag.pointerType = e.pointerType || 'mouse';
  Engine.drag.button = e.button || 0;
  Engine.drag.mode = 1;
  Engine.drag.originSx = Engine.drag.startSx = Engine.drag.sx = e.clientX;
  Engine.drag.originSy = Engine.drag.startSy = Engine.drag.sy = e.clientY;
  if (isOnMinimap(e.clientX, e.clientY)) {
    Engine.drag.mode = 4;
    focusCameraFromMinimap(e.clientX, e.clientY);
    return;
  }
  toWorld(e.clientX, e.clientY);
  Engine.drag.startWx = Engine.drag.wx = Temp[0];
  Engine.drag.startWy = Engine.drag.wy = Temp[1];
  Engine.drag.overOwnUnit = pickUnitAt(Engine.drag.wx, Engine.drag.wy, 0);
  if (Engine.buildType !== 0) return;
});

canvas.addEventListener('pointermove', (e) => {
  if (!Engine.drag.active) return;
  if (e.pointerId !== Engine.drag.pointerId) return;
  e.preventDefault();
  Engine.drag.sx = e.clientX;
  Engine.drag.sy = e.clientY;
  if (Engine.drag.mode === 4) {
    focusCameraFromMinimap(e.clientX, e.clientY);
    return;
  }
  screenToWorldUpdate(e);
  const dx = e.clientX - Engine.drag.originSx;
  const dy = e.clientY - Engine.drag.originSy;
  const moved = dx * dx + dy * dy;

  if (Engine.buildType !== 0) return;

  if (Engine.drag.mode === 1 && moved > TAP_SLOP2) {
    const mouse = Engine.drag.pointerType === 'mouse';
    const panButton = mouse && (Engine.drag.button === 1 || Engine.drag.button === 2);
    if (panButton) {
      Engine.drag.mode = 2;
    } else if (mouse || Engine.drag.overOwnUnit !== -1) {
      Engine.drag.mode = 3;
      Engine.drag.boxX0 = Engine.drag.startWx;
      Engine.drag.boxY0 = Engine.drag.startWy;
      Engine.drag.boxX1 = Engine.drag.wx;
      Engine.drag.boxY1 = Engine.drag.wy;
    } else {
      Engine.drag.mode = 2;
    }
  }

  if (Engine.drag.mode === 2) {
    Engine.cam.x -= (e.clientX - Engine.drag.startSx) / Engine.cam.z;
    Engine.cam.y -= (e.clientY - Engine.drag.startSy) / Engine.cam.z;
    clampCamera();
    Engine.drag.startSx = e.clientX;
    Engine.drag.startSy = e.clientY;
  } else if (Engine.drag.mode === 3) {
    Engine.drag.boxX1 = Engine.drag.wx;
    Engine.drag.boxY1 = Engine.drag.wy;
  }
});

canvas.addEventListener('pointerup', (e) => {
  if (!Engine.drag.active) return;
  if (e.pointerId !== Engine.drag.pointerId) return;
  e.preventDefault();
  if (Engine.drag.mode === 4) {
    focusCameraFromMinimap(e.clientX, e.clientY);
    resetDrag();
    return;
  }
  screenToWorldUpdate(e);
  const movedX = e.clientX - Engine.drag.originSx;
  const movedY = e.clientY - Engine.drag.originSy;
  const tap = Engine.drag.mode === 1 && movedX * movedX + movedY * movedY < TAP_SLOP2;
  const mouse = Engine.drag.pointerType === 'mouse';
  const button = Engine.drag.button;

  if (Engine.placingStart) {
    if (tap) Game.placePlayerStart(Engine.drag.wx, Engine.drag.wy);
    resetDrag();
    return;
  }

  if (Engine.buildType !== 0) {
    if (mouse && button === 2) {
      UI.cancelBuild();
      resetDrag();
      return;
    }
    const type = Engine.buildType;
    const cfg = BuildCfg[type];
    const gx = (Engine.drag.wx / TILE) | 0;
    const gy = (Engine.drag.wy / TILE) | 0;
    const f = Factions[0];
    if (f.current[type] >= f.limits[type]) UI.msg('Limite atingido para esta construção.', true);
    else if (bFree.length === 0) UI.msg('Limite global de construções atingido.', true);
    else if (!canAfford(0, type)) UI.msg('Recursos insuficientes.', true);
    else if (!canPlaceBuilding(gx, gy, cfg.w, cfg.h)) UI.msg('Local inválido ou ocupado.', true);
    else {
      payForBuild(0, type);
      const b = spawnBuilding(0, type, gx, gy);
      if (b !== -1) {
        UI.updateRes();
        UI.updateLimits();
        UI.cancelBuild();
      }
    }
    resetDrag();
    return;
  }

  if (Engine.drag.mode === 3) {
    finalizeSelectionBox();
    resetDrag();
    return;
  }

  if (tap) {
    const wx = Engine.drag.wx, wy = Engine.drag.wy;
    if (mouse && button === 2) issueCommandAt(wx, wy);
    else if (!mouse || button === 0) handlePrimaryTap(wx, wy, Engine.drag.pointerType);
  }

  resetDrag();
});

canvas.addEventListener('pointercancel', (e) => {
  if (!Engine.drag.active || e.pointerId !== Engine.drag.pointerId) return;
  resetDrag();
});

canvas.addEventListener('contextmenu', (e) => e.preventDefault());

const UI = {
  resWood: -1,
  resStone: -1,
  resGrain: -1,
  limitCache: {},
  selectionText: '',
  spawnVisible: false,
  spawnText: '',
  toBotMenu() {
    document.getElementById('mainMenu').classList.add('hidden');
    document.getElementById('endMenu').classList.add('hidden');
    document.getElementById('botMenu').classList.remove('hidden');
  },
  showEnd(victory) {
    document.getElementById('uiLayer').classList.add('hidden');
    document.getElementById('botMenu').classList.add('hidden');
    document.getElementById('mainMenu').classList.add('hidden');
    document.getElementById('endTitle').textContent = victory ? 'Vitória' : 'Derrota';
    document.getElementById('endSubtitle').textContent = victory ? 'As prefeituras inimigas caíram.' : 'Sua prefeitura foi destruída.';
    document.getElementById('endMenu').classList.remove('hidden');
  },
  prepBuild(type) {
    if (Engine.placingStart) {
      UI.msg('Escolha a prefeitura inicial primeiro.', true);
      return;
    }
    const f = Factions[0];
    if (f.current[type] >= f.limits[type]) {
      UI.msg('Limite atingido para esta construção.', true);
      return;
    }
    Engine.buildType = type;
    document.getElementById('cancelBuild').classList.remove('hidden');
    UI.updateSelectionInfo();
  },
  cancelBuild() {
    Engine.buildType = 0;
    document.getElementById('cancelBuild').classList.add('hidden');
    UI.updateSelectionInfo();
  },
  msg(txt, err) {
    const box = document.getElementById('msgBox');
    box.textContent = txt;
    box.style.color = err ? '#ff8f8f' : '#fff';
    box.style.opacity = '1';
    Engine.msgTimer = 2.0;
  },
  updateRes() {
    const f = Factions[0];
    const wood = f.wood | 0;
    const stone = f.stone | 0;
    const grain = f.grain | 0;
    if (UI.resWood !== wood) {
      document.getElementById('valWood').textContent = wood;
      UI.resWood = wood;
    }
    if (UI.resStone !== stone) {
      document.getElementById('valStone').textContent = stone;
      UI.resStone = stone;
    }
    if (UI.resGrain !== grain) {
      document.getElementById('valGrain').textContent = grain;
      UI.resGrain = grain;
    }
  },
  updateLimits() {
    const f = Factions[0];
    for (const type of [B_MINE, B_WOOD, B_FARM, B_BARR]) {
      const txt = `(${f.current[type]}/${f.limits[type]})`;
      if (UI.limitCache[type] === txt) continue;
      const el = document.getElementById('lim-' + type);
      if (el) el.textContent = txt;
      UI.limitCache[type] = txt;
    }
  },
  updateSelectionInfo() {
    const label = document.getElementById('selectionInfo');
    const spawn = document.getElementById('spawnUnit');
    let text = 'Sem seleção';
    let showSpawn = false;
    let spawnHtml = 'Soldado<small>10G</small>';
    if (Engine.placingStart) {
      text = 'Escolha sua prefeitura inicial';
    } else if (Engine.buildType !== 0) {
      text = 'Posicione: ' + buildingLabel(Engine.buildType);
    } else if (Engine.selectedBuilding !== -1) {
      const bId = Engine.selectedBuilding;
      text = buildingLabel(Builds.type[bId]);
      if (Builds.type[bId] === B_BARR) {
        const q = Builds.queueCount[bId];
        const t = Math.ceil(Builds.queue[bId]);
        text = q > 0 ? `Quartel - Fila ${q}/${MAX_TRAIN_QUEUE} (${t}s)` : `Quartel - Fila 0/${MAX_TRAIN_QUEUE}`;
        spawnHtml = q >= MAX_TRAIN_QUEUE ? 'Soldado<small>Fila cheia</small>' : `Soldado<small>10G Fila ${q}/${MAX_TRAIN_QUEUE}</small>`;
        showSpawn = true;
      }
    } else if (Sel.count > 0) {
      text = Sel.count === 1 ? '1 unidade selecionada' : `${Sel.count} unidades selecionadas`;
    }
    if (UI.selectionText !== text) {
      label.textContent = text;
      UI.selectionText = text;
    }
    if (UI.spawnVisible !== showSpawn) {
      spawn.classList.toggle('hidden', !showSpawn);
      UI.spawnVisible = showSpawn;
    }
    if (UI.spawnText !== spawnHtml) {
      spawn.innerHTML = spawnHtml;
      UI.spawnText = spawnHtml;
    }
  }
};

const Game = {
  reset() {
    mapGrid.fill(-1);
    hashHead.fill(-1);
    for (let i = 0; i < MAX_U; i++) Units.active[i] = 0;
    for (let i = 0; i < MAX_B; i++) Builds.active[i] = 0;
    uFree.length = 0; bFree.length = 0;
    for (let i = MAX_U - 1; i >= 0; i--) uFree.push(i);
    for (let i = MAX_B - 1; i >= 0; i--) bFree.push(i);
    Factions.length = 0;
    Sel.count = 0;
    Engine.selectedBuilding = -1;
    Engine.buildType = 0;
    Engine.placingStart = false;
    Engine.pendingBotCount = 0;
    Engine.msgTimer = 0;
    Engine.econAcc = 0;
    Engine.botAcc = 0;
    Engine.uidGen = 1;
    Engine.cam.x = WORLD_SZ / 2;
    Engine.cam.y = WORLD_SZ / 2;
    Engine.cam.z = 1;
    Pings.count = 0;
  },
  start(botCount) {
    Game.reset();
    document.getElementById('botMenu').classList.add('hidden');
    document.getElementById('endMenu').classList.add('hidden');
    document.getElementById('uiLayer').classList.remove('hidden');

    createFaction(false); // player = 0
    for (let i = 0; i < botCount; i++) createFaction(true);

    Engine.placingStart = true;
    Engine.pendingBotCount = botCount;

    UI.updateRes();
    UI.updateLimits();
    UI.updateSelectionInfo();
    UI.msg('Escolha onde construir sua prefeitura.', false);

    Engine.running = true;
    Engine.lastTime = performance.now();
    Engine.acc = 0;
    requestAnimationFrame(loop);
  },
  placePlayerStart(wx, wy) {
    if (!Engine.placingStart) return;
    const cfg = BuildCfg[B_HALL];
    startTileFromWorld(wx, wy);
    const tx = Temp[0] | 0;
    const ty = Temp[1] | 0;
    if (!canPlaceBuilding(tx, ty, cfg.w, cfg.h)) {
      UI.msg('Local invalido para a prefeitura.', true);
      return;
    }

    const hall = spawnBuilding(0, B_HALL, tx, ty);
    if (hall === -1) {
      UI.msg('Nao foi possivel posicionar a prefeitura.', true);
      return;
    }

    const placedBots = placeBotStarts(Engine.pendingBotCount);
    Engine.placingStart = false;
    Engine.pendingBotCount = 0;
    Engine.cam.x = (Builds.tx[hall] + Builds.w[hall] * 0.5) * TILE;
    Engine.cam.y = (Builds.ty[hall] + Builds.h[hall] * 0.5) * TILE;
    clampCamera();
    UI.updateRes();
    UI.updateLimits();
    UI.updateSelectionInfo();
    if (placedBots > 0) UI.msg('Base posicionada. Prepare sua economia e seu exercito.', false);
    else UI.msg('Base posicionada. Nenhum bot encontrou uma posicao valida.', true);
  },
  end(victory) {
    if (!Engine.running) return;
    Engine.running = false;
    UI.cancelBuild();
    UI.showEnd(victory);
  },
  requestUnit() {
    if (Engine.selectedBuilding === -1 || !Builds.active[Engine.selectedBuilding] || Builds.type[Engine.selectedBuilding] !== B_BARR) {
      UI.msg('Selecione um quartel.', true);
      return;
    }
    if (!canTrainUnit(0)) {
      UI.msg('Limite de unidades atingido.', true);
      return;
    }
    if (Builds.queueCount[Engine.selectedBuilding] >= MAX_TRAIN_QUEUE) {
      UI.msg('Fila do quartel cheia.', true);
      return;
    }
    if (Factions[0].grain < UnitCfg.grainCost) {
      UI.msg('Grao insuficiente para treinar soldado.', true);
      return;
    }
    if (!queueUnitFromBarracks(Engine.selectedBuilding)) {
      UI.msg('Nao foi possivel adicionar a unidade na fila.', true);
      return;
    }
    UI.updateRes();
    UI.updateSelectionInfo();
  }
};

function update(dt) {
  Engine.pulse += dt;
  if (Engine.pulse > Math.PI * 2) Engine.pulse -= Math.PI * 2;
  rebuildHash();
  updateUnits(dt);
  updateBuildingFeedback(dt);
  updateProduction(dt);
  updatePings(dt);
  updateEconomy(dt);
  updateBots(dt);
  checkGameOver();

  if (Engine.msgTimer > 0) {
    Engine.msgTimer -= dt;
    if (Engine.msgTimer <= 0) document.getElementById('msgBox').style.opacity = '0';
  }

  UI.updateSelectionInfo();
  UI.updateLimits();
  UI.updateRes();
}

function loop(now) {
  if (!Engine.running) return;
  let dt = (now - Engine.lastTime) / 1000;
  if (dt > 0.1) dt = 0.1;
  Engine.lastTime = now;
  Engine.acc += dt;

  while (Engine.running && Engine.acc >= FIXED_STEP) {
    update(FIXED_STEP);
    Engine.acc -= FIXED_STEP;
  }

  if (!Engine.running) {
    render();
    return;
  }

  render();
  requestAnimationFrame(loop);
}
</script>
